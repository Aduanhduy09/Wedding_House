@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biên Lai Đặt Tiệc Cưới — Wedding House</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            :root {
                --gold: #C9A84C;
                --navy: #0E1B2E;
                --ivory: #FAF7F2;
                --font-display: 'Cormorant Garamond', Georgia, serif;
                --font-body: 'Jost', sans-serif;
            }

            body {
                font-family: var(--font-body);
                background: #f3f4f6;
                color: var(--navy);
                padding: 3rem 0;
            }

            .invoice-box {
                max-width: 750px;
                margin: auto;
                background: #fff;
                border: 1px solid rgba(14,27,46,0.08);
                box-shadow: 0 15px 50px rgba(0,0,0,0.05);
                position: relative;
            }

            .invoice-header {
                background: var(--navy);
                color: #fff;
                padding: 2.5rem;
                border-bottom: 4px solid var(--gold);
            }

            .brand-title {
                font-family: var(--font-display);
                font-size: 2.2rem;
                font-style: italic;
                color: var(--gold);
                margin: 0;
            }

            .status-badge {
                background: #FEF3C7;
                color: #D97706;
                border: 1px solid #FCD34D;
                padding: 0.4rem 1.2rem;
                font-size: 0.85rem;
                font-weight: 500;
                letter-spacing: 0.05em;
                text-transform: uppercase;
            }

            .info-title {
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #6B7280;
                margin-bottom: 0.25rem;
            }

            .info-value {
                font-weight: 500;
                color: var(--navy);
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="invoice-box">
            <!-- HEADER BIÊN LAI -->
            <div class="invoice-header d-flex justify-content-between align-items-center flex-wrap g-3">
                <div>
                    <h2 class="brand-title">Wedding House</h2>
                    <p class="small text-white-50 m-0">Nơi Chắp Cánh Cho Hạnh Phúc Lứa Đôi</p>
                </div>
                <div class="text-md-end">
                    <h4 class="m-0 text-white font-weight-300 tracking-wide" style="font-size: 1.2rem;">BIÊN LAI ĐẶT TIỆC</h4>
                    <p class="small text-white-50 m-0" id="txtNgayLap">Ngày lập: --/--/----</p>
                </div>
            </div>

            <!-- NỘI DUNG CHI TIẾT -->
            <div class="p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom flex-wrap g-2">
                    <div>
                        <span class="small text-muted">Mã định danh đơn tiệc:</span>
                        <strong class="text-danger ms-1" id="txtMaDon">#0000</strong>
                    </div>
                    <!-- STATUS BADGE CHỜ DUYỆT CỦA NHÀ HÀNG -->
                    <div class="status-badge">
                        <i class="bi bi-clock-history me-1"></i> Trạng thái: Chờ duyệt
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-6 col-sm-3">
                        <div class="info-title">Chủ nhân tiệc cưới</div>
                        <div class="info-value" id="txtTenKhach">--</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="info-title">Đại sảnh lựa chọn</div>
                        <div class="info-value" id="txtSanh">--</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="info-title">Ngày tổ chức cưới</div>
                        <div class="info-value" id="txtNgayCuoi">--/--/----</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="info-title">Thời gian (Ca)</div>
                        <div class="info-value" id="txtCa">--</div>
                    </div>
                </div>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light small text-uppercase">
                            <tr>
                                <th>Hạng Mục Dịch Vụ / Thực Đơn</th>
                                <th class="text-center" style="width: 120px;">Số lượng bàn</th>
                                <th class="text-end" style="width: 180px;">Tổng chi phí tạm tính</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <strong>Chi phí thực đơn bàn tiệc phục vụ</strong>
                                    <p class="small text-muted m-0">Bao gồm danh sách các món ăn tinh tuyển do khách hàng tự lựa chọn phối hợp.</p>
                                </td>
                                <td class="text-center" id="tableSoBan">0</td>
                                <td class="text-end text-muted" id="tableTienMon">0 VNĐ</td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>Chi phí bản quyền thuê không gian sảnh</strong>
                                    <p class="small text-muted m-0">Phí giữ chỗ, trang trí hoa tươi cơ bản, hệ thống âm thanh ánh sáng sân khấu trọn gói.</p>
                                </td>
                                <td class="text-center">1 sảnh</td>
                                <td class="text-end text-muted" id="tableTienSanh">0 VNĐ</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- TỔNG TIỀN BIÊN LAI -->
                <div class="d-flex justify-content-end align-items-center gap-3 bg-light p-3 border mb-5">
                    <span class="text-uppercase small tracking-wider text-muted font-weight-500">Thành tiền toàn bộ hóa đơn:</span>
                    <h3 class="text-danger m-0 font-weight-600" id="txtTongTien">0 VNĐ</h3>
                </div>

                <!-- KHUYÊN BẢO CHĂM SÓC KHÁCH HÀNG -->
                <div class="alert alert-secondary rounded-0 small text-muted border-0 p-3 mb-4">
                    <i class="bi bi-info-circle-fill text-dark me-2"></i>
                    <strong>Lưu ý từ ban quản lý Wedding House:</strong> Biên lai này được tạo tự động bởi hệ thống lập kế hoạch trực tuyến. Lịch trống của đại sảnh hiện tại đang được tạm giữ tạm thời cho bạn trong vòng 24 giờ. Quản trị viên của nhà hàng sẽ sớm gọi điện trực tiếp để xác nhận và phê duyệt hợp đồng chính thức.
                </div>

                <div class="text-center">
                    <a href="/Home/Index" class="btn btn-navy text-white rounded-0 px-4 me-2"><i class="bi bi-house me-1"></i> Về Trang Chủ</a>
                    <button class="btn btn-outline-dark rounded-0 px-4" onclick="window.print()"><i class="bi bi-printer me-1"></i> In Biên Lai này</button>
                </div>
            </div>
        </div>
    </div>

    <script>
                                  document.addEventListener('DOMContentLoaded', async () => {
                // 1. Lấy mã ID đơn hàng từ thanh URL địa chỉ trình duyệt (?id=...)
                const urlParams = new URLSearchParams(window.location.search);
                const bookingId = urlParams.get('id');

                if(!bookingId) {
                    alert('Không tìm thấy mã hóa đơn hợp lệ!');
                    window.location.href = '/Home/Index';
                    return;
                }

                // 🌟 ĐÃ SỬA TẠI ĐÂY: Ưu tiên bốc họ tên đầy đủ từ trình duyệt
                const username = localStorage.getItem('username');
                const fullName = localStorage.getItem('fullName') || username || 'Khách Hàng';

                // Gán thông tin mã đơn và ngày lập tự động ban đầu
                document.getElementById('txtMaDon').innerText = `#WHD-${bookingId}`;
                document.getElementById('txtNgayLap').innerText = `Ngày lập: ${new Date().toLocaleDateString('vi-VN')}`;

                // 🌟 ĐÃ SỬA TẠI ĐÂY: Gán họ tên đầy đủ vào vị trí Chủ nhân tiệc cưới
                const txtTenKhach = document.getElementById('txtTenKhach');
                if (txtTenKhach) {
                    txtTenKhach.innerText = fullName;
                }

                try {
                    // 2. Gọi API bốc dữ liệu thật vừa được xử lý an toàn từ BookingController
                    const res = await fetch(`/api/Booking/details/${bookingId}`);
                    if (!res.ok) throw new Error('Không thể tải chi tiết đơn hàng từ máy chủ');

                    const data = await res.json();

                    // 3. Tiến hành gán nạp toàn bộ số liệu động bốc từ DB lên giao diện
                    document.getElementById('txtSanh').innerText = data.tenSanh;
                    document.getElementById('txtNgayCuoi').innerText = data.ngayCuoi;
                    document.getElementById('txtCa').innerText = data.ca;

                    // Cấu hình các thẻ hiển thị số bàn tiệc cưới
                    const txtSoBan = document.getElementById('txtSoBan');
                    if (txtSoBan) txtSoBan.innerText = `${data.soBan} bàn`;

                    const tableSoBan = document.getElementById('tableSoBan');
                    if (tableSoBan) tableSoBan.innerText = data.soBan;

                    // Đổ số liệu tiền tệ kèm định dạng dấu chấm phân tách hàng nghìn chuẩn VNĐ
                    const tableTienSanh = document.getElementById('tableTienSanh');
                    if (tableTienSanh) {
                        tableTienSanh.innerText = data.tienSanh === 0 ? "Miễn phí (0 VNĐ)" : `${data.tienSanh.toLocaleString('vi-VN')} VNĐ`;
                    }

                    const tableTienMon = document.getElementById('tableTienMon');
                    if (tableTienMon) {
                        tableTienMon.innerText = `${data.tienMonAn.toLocaleString('vi-VN')} VNĐ`;
                    }

                    // Tìm và cập nhật trọn vẹn số tiền tổng (ví dụ: 52,500,000 VNĐ) ở mục Thành Tiền
                    const txtTongTien = document.getElementById('txtTongTien');
                    if (txtTongTien) {
                        txtTongTien.innerText = `${data.tongTien.toLocaleString('vi-VN')} VNĐ`;
                    } else {
                        // Săn lùng theo Class hoặc cấu trúc thẻ nếu giao diện đang thiết kế theo khung mẫu cũ
                        const totalBoxes = document.querySelectorAll('.text-danger.m-0.font-weight-600') || document.querySelectorAll('h3.text-danger');
                        totalBoxes.forEach(box => {
                            box.innerText = `${data.tongTien.toLocaleString('vi-VN')} VNĐ`;
                        });
                    }

                } catch (err) {
                    console.error(err);
                    // Đoạn này bẫy lỗi hiển thị thông báo cũ của bạn nếu có phần tử HTML nào bị null
                    alert('Có lỗi xảy ra khi kết nối đồng bộ hóa dữ liệu biên lai.');
                }
            });
    </script>
</body>
</html>