@{
    // Cắt đứt liên kết với Layout Admin để không bị lỗi quyền truy cập
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý tài khoản - Wedding House</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

    <style>
            body {
                font-family: 'Jost', sans-serif;
                background-color: #FAF7F2;
            }

            /* NAVBAR ĐƠN GIẢN */
            .wh-navbar {
                background: #0E1B2E;
                padding: 0.75rem 0;
                border-bottom: 1px solid rgba(201,168,76,0.25);
            }

                .wh-navbar .navbar-brand {
                    font-family: 'Cormorant Garamond', serif;
                    font-size: 1.5rem;
                    color: #C9A84C !important;
                }

            /* MENU TAB BÊN TRÁI */
            .account-menu .list-group-item {
                border-radius: 0 !important;
                border-left: 3px solid transparent;
                color: #0E1B2E;
                transition: all 0.3s;
            }

                .account-menu .list-group-item:hover {
                    background-color: #F5EDDA;
                }

                .account-menu .list-group-item.active {
                    background-color: #0E1B2E;
                    color: #C9A84C;
                    border-left: 3px solid #C9A84C;
                    border-color: #0E1B2E;
                }

            .custom-card {
                border-top: 3px solid #C9A84C;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg wh-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/Index">
                <i class="bi bi-heart-fill fs-6 me-1"></i> Wedding House
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-white-50 small text-uppercase">
                    <i class="bi bi-person-circle text-warning me-1"></i> Xin chào,
                    <strong class="text-white" id="navUserFullName">Đang tải...</strong>
                </span>
                <a href="/Home/Index" class="btn btn-outline-light btn-sm rounded-0">
                    <i class="bi bi-arrow-left"></i> Về Trang Chủ
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5" style="margin-top: 80px; min-height: 70vh;">
        <h2 class="mb-4" style="font-family: 'Cormorant Garamond', serif; color: #0E1B2E; font-style: italic;">
            Tài khoản của tôi
        </h2>

        <div class="row align-items-start">
            <div class="col-md-3 mb-4">
                <div class="list-group account-menu shadow-sm" id="list-tab" role="tablist">
                    <a class="list-group-item list-group-item-action active py-3" id="list-profile-list" data-bs-toggle="list" href="#list-profile" role="tab">
                        <i class="bi bi-person-lines-fill me-2"></i> Thông tin tài khoản
                    </a>
                    <a class="list-group-item list-group-item-action py-3" id="list-history-list" data-bs-toggle="list" href="#list-history" role="tab">
                        <i class="bi bi-clock-history me-2"></i> Lịch sử đặt tiệc
                    </a>
                </div>
            </div>

            <div class="col-md-9">
                <div class="tab-content" id="nav-tabContent">

                    <div class="tab-pane fade show active" id="list-profile" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-0 p-4 custom-card">
                            <h4 class="mb-4" style="font-family: 'Cormorant Garamond', serif;">Hồ sơ cá nhân</h4>

                            <form id="formUpdateAccount" class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small text-muted text-uppercase">Mã Khách Hàng</label>
                                    <input type="text" class="form-control rounded-0 bg-light" id="txtMaKhachHang" readonly>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label small text-muted text-uppercase">Họ và tên đầy đủ</label>
                                    <input type="text" class="form-control rounded-0" id="txtFullName" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted text-uppercase">Tên đăng nhập</label>
                                    <input type="text" class="form-control rounded-0 bg-light" id="txtUsername" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted text-uppercase">Số điện thoại</label>
                                    <input type="tel" class="form-control rounded-0" id="txtPhone">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label small text-muted text-uppercase">Email</label>
                                    <input type="email" class="form-control rounded-0" id="txtEmail">
                                </div>
                                <div class="col-12 text-end mt-4">
                                    <button type="button" onclick="alert('Chức năng Update DB đang được xây dựng!')" class="btn text-white rounded-0 px-4" style="background-color: #0E1B2E;">Lưu thay đổi</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="list-history" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-0 p-4 custom-card">
                            <h4 class="mb-4" style="font-family: 'Cormorant Garamond', serif;">Lịch sử đặt tiệc của bạn</h4>

                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead style="background-color: #F5EDDA; color: #0E1B2E;">
                                        <tr>
                                            <th>Mã Đơn</th>
                                            <th>Ngày Đãi Tiệc</th>
                                            <th>Sảnh / Ca</th>
                                            <th>Tên Cô Dâu - Chú Rể</th>
                                            <th>Thành Tiền</th>
                                            <th>Tiền Cọc</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableHistoryBody">
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">
                                                <span class="spinner-border spinner-border-sm me-2 text-warning"></span> Đang tải lịch sử...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
        // Chỉ lấy username từ trình duyệt làm "chìa khóa"
        const username = localStorage.getItem('username');

        if (!username) {
        alert("Vui lòng đăng nhập để xem thông tin!");
        window.location.href = '/Home/Index';
        return;
        }

        // Gắn tên đăng nhập vào ô nhập liệu
        document.getElementById('txtUsername').value = username;

        // GỌI API LẤY DỮ LIỆU TỪ DATABASE
        try {
        // Đảm bảo API này đã được tạo trong Controller như hướng dẫn ở bước trước
        // Trỏ đúng về TaikhoanController của bạn
        const res = await fetch(`/api/Taikhoan/get-profile?username=${username}`);

        if (res.ok) {
        const dbData = await res.json();

        // Đổ dữ liệu từ SQL Server lên Giao diện
        document.getElementById('navUserFullName').innerText = dbData.hoTen;
        document.getElementById('txtMaKhachHang').value = dbData.maKhachHang;
        document.getElementById('txtFullName').value = dbData.hoTen;
        document.getElementById('txtPhone').value = dbData.dienThoai || '';
        document.getElementById('txtEmail').value = dbData.email || '';

        // Cập nhật lại bộ nhớ đệm phòng hờ
        localStorage.setItem('fullName', dbData.hoTen);
        } else {
        document.getElementById('navUserFullName').innerText = username;
        console.warn("Chưa thể kết nối tới DB, đang hiển thị tạm.");
        }
        } catch (err) {
        document.getElementById('navUserFullName').innerText = username;
        console.error("Lỗi khi bốc dữ liệu từ DB:", err);
        }

        // Bắt sự kiện khi bấm qua Tab Lịch Sử
        const historyTab = document.getElementById('list-history-list');
        historyTab.addEventListener('shown.bs.tab', function () {
        loadBookingHistory(username);
        });
        });

        // Hàm gọi API lấy lịch sử đặt tiệc
        async function loadBookingHistory(username) {
        const tbody = document.getElementById('tableHistoryBody');
        if (!username) return;

        try {
        const response = await fetch(`/api/Taikhoan/history?username=${username}`);
        if (!response.ok) throw new Error('Network error');

        const data = await response.json();
        if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">Chưa có đơn đặt tiệc.</td></tr>';
        return;
        }

        tbody.innerHTML = '';
        data.forEach(item => {
        // 1. TÍNH TOÁN TIỀN (Quy định cọc 20%)
        const tienThanhTien = item.tongTien || 0;
        const tienCocGoc = tienThanhTien * 0.20;

        // Lấy trạng thái do Admin quyết định (Mặc định 0 là Chờ thanh toán)
        const trangThaiDon = item.trangThai || 0;

        // 2. TÍNH NGÀY TRỄ & TIỀN PHẠT (Chỉ phạt nếu trạng thái đang là 0)
        let soNgayTre = 0;
        let tienPhat = 0;

        if (trangThaiDon === 0) {
        const ngayLapDon = new Date(item.ngayLap || new Date());
        const ngayHienTai = new Date();
        const diffTime = ngayHienTai - ngayLapDon;
        const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

        soNgayTre = diffDays > 1 ? diffDays - 1 : 0;
        tienPhat = soNgayTre * (tienThanhTien * 0.01);
        }

        const tongTienCocCanThanhToan = tienCocGoc + tienPhat;

        // 3. NỘI SUY TRẠNG THÁI & NÚT THANH TOÁN (Dựa hoàn toàn vào Admin)
        let statusBadge = '';
        let actionBtn = '';

        if (trangThaiDon === 0) {
        statusBadge = `<span class="badge bg-warning text-dark">Chờ thanh toán cọc</span>`;
        // Nút bấm này sẽ gọi hàm hiển thị thông tin chuyển khoản (QR code) cho khách
        actionBtn = `<button class="btn btn-sm text-white rounded-0" style="background-color: #0E1B2E;" onclick="thanhToanCoc(${item.maDatTiecCuoi}, ${tongTienCocCanThanhToan})">Thanh toán cọc</button>`;
        } else if (trangThaiDon === 1) {
        statusBadge = `<span class="badge bg-info text-dark">Đã thanh toán cọc</span>`;
        actionBtn = `<span class="text-muted small">Chờ tất toán</span>`;
        } else {
        statusBadge = `<span class="badge bg-success">Đã hoàn tất</span>`;
        actionBtn = `<i class="bi bi-check-circle-fill text-success fs-5"></i>`;
        }

        // Ghi chú hiển thị màu đỏ nếu có phạt
        let ghiChuPhat = soNgayTre > 0 ? `<br><small class="text-danger">(+${tienPhat.toLocaleString('vi-VN')} đ phạt trễ ${soNgayTre} ngày)</small>` : '';

        // Đổ HTML vào bảng
        tbody.innerHTML += `
        <tr>
        <td class="fw-bold text-primary">#WHD-${item.maDatTiecCuoi}</td>
        <td>${new Date(item.ngayDaiTiec).toLocaleDateString('vi-VN')}</td>
        <td>Sảnh ${item.maSanh} <br><small class="text-muted">Ca: ${item.maCa}</small></td>
        <td>${item.tenCoDau} - ${item.tenChuRe}</td>
        <td class="fw-bold">${tienThanhTien.toLocaleString('vi-VN')} đ</td>
        <td class="fw-bold text-danger">
        ${tongTienCocCanThanhToan.toLocaleString('vi-VN')} đ
        ${ghiChuPhat}
        </td>
        <td>${statusBadge}</td>
        <td>${actionBtn}</td>
        </tr>
        `;
        });
        } catch (error) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-danger py-4">Lỗi tải dữ liệu. Bạn hãy kiểm tra lại API!</td></tr>';
        }
        }
    </script>
</body>
</html>