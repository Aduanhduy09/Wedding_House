@{
    // Cắt đứt liên kết với Layout Admin để không bị lỗi quyền truy cập
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý tài khoản - Wedding House</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

    <style>
            body {
                font-family: 'Jost', sans-serif;
                background-color: #FAF7F2;
            }

            /* NAVBAR ĐƠN GIẢN */
            .wh-navbar {
                background: #0E1B2E;
                padding: 0.75rem 0;
                border-bottom: 1px solid rgba(201,168,76,0.25);
            }

                .wh-navbar .navbar-brand {
                    font-family: 'Cormorant Garamond', serif;
                    font-size: 1.5rem;
                    color: #C9A84C !important;
                }

            /* MENU TAB BÊN TRÁI */
            .account-menu .list-group-item {
                border-radius: 0 !important;
                border-left: 3px solid transparent;
                color: #0E1B2E;
                transition: all 0.3s;
            }

                .account-menu .list-group-item:hover {
                    background-color: #F5EDDA;
                }

                .account-menu .list-group-item.active {
                    background-color: #0E1B2E;
                    color: #C9A84C;
                    border-left: 3px solid #C9A84C;
                    border-color: #0E1B2E;
                }

            .custom-card {
                border-top: 3px solid #C9A84C;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg wh-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/Index">
                <i class="bi bi-heart-fill fs-6 me-1"></i> Wedding House
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-white-50 small text-uppercase">
                    <i class="bi bi-person-circle text-warning me-1"></i> Xin chào,
                    <strong class="text-white" id="navUserFullName">Đang tải...</strong>
                </span>
                <a href="/Home/Index" class="btn btn-outline-light btn-sm rounded-0">
                    <i class="bi bi-arrow-left"></i> Về Trang Chủ
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5" style="margin-top: 80px; min-height: 70vh;">
        <h2 class="mb-4" style="font-family: 'Cormorant Garamond', serif; color: #0E1B2E; font-style: italic;">
            Tài khoản của tôi
        </h2>

        <div class="row align-items-start">
            <div class="col-md-3 mb-4">
                <div class="list-group account-menu shadow-sm" id="list-tab" role="tablist">
                    <a class="list-group-item list-group-item-action active py-3" id="list-profile-list" data-bs-toggle="list" href="#list-profile" role="tab">
                        <i class="bi bi-person-lines-fill me-2"></i> Thông tin tài khoản
                    </a>
                    <a class="list-group-item list-group-item-action py-3" id="list-history-list" data-bs-toggle="list" href="#list-history" role="tab">
                        <i class="bi bi-clock-history me-2"></i> Lịch sử đặt tiệc
                    </a>
                </div>
            </div>

            <div class="col-md-9">
                <div class="tab-content" id="nav-tabContent">

                    <div class="tab-pane fade show active" id="list-profile" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-0 p-4 custom-card">
                            <h4 class="mb-4" style="font-family: 'Cormorant Garamond', serif;">Hồ sơ cá nhân</h4>

                            <form id="formUpdateAccount" class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label small text-muted text-uppercase">Mã Khách Hàng</label>
                                    <input type="text" class="form-control rounded-0 bg-light" id="txtMaKhachHang" readonly>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label small text-muted text-uppercase">Họ và tên đầy đủ</label>
                                    <input type="text" class="form-control rounded-0" id="txtFullName" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted text-uppercase">Tên đăng nhập</label>
                                    <input type="text" class="form-control rounded-0 bg-light" id="txtUsername" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted text-uppercase">Số điện thoại</label>
                                    <input type="tel" class="form-control rounded-0" id="txtPhone">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label small text-muted text-uppercase">Email</label>
                                    <input type="email" class="form-control rounded-0" id="txtEmail">
                                </div>
                                <div class="col-12 text-end mt-4">
                                    <button type="button" onclick="alert('Chức năng Update DB đang được xây dựng!')" class="btn text-white rounded-0 px-4" style="background-color: #0E1B2E;">Lưu thay đổi</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="list-history" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-0 p-4 custom-card">
                            <h4 class="mb-4" style="font-family: 'Cormorant Garamond', serif;">Lịch sử đặt tiệc của bạn</h4>

                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead style="background-color: #F5EDDA; color: #0E1B2E;">
                                        <tr>
                                            <th>Mã Đơn</th>
                                            <th>Ngày Đãi Tiệc</th>
                                            <th>Sảnh / Ca</th>
                                            <th>Tên Cô Dâu - Chú Rể</th>
                                            <th>Thành Tiền</th>
                                            <th>Tiền Cọc</th>
                                            <th>Trạng Thái</th>
                                            <th>Thao Tác</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableHistoryBody">
                                        <tr>
                                            <td colspan="8" class="text-center py-4 text-muted">
                                                <span class="spinner-border spinner-border-sm me-2 text-warning"></span> Đang tải lịch sử...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 650px;">
            <div class="modal-content rounded-0 border-0 shadow">
                <div class="modal-header text-white rounded-0" style="background-color: #0E1B2E; border-bottom: 2px solid #C9A84C;">
                    <h5 class="modal-title" style="font-family: 'Cormorant Garamond', serif; font-size: 1.35rem;">
                        <i class="bi bi-qr-code-scan me-2 text-warning"></i>Thanh Toán Tiền Cọc Giữ Sảnh
                    </h5>
                    <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4 bg-white">
                    <div class="row align-items-center">
                        <div class="col-sm-5 text-center mb-3 mb-sm-0">
                            <img src="/image/image_124000.jpg" alt="Mã QR PVcomBank" class="img-fluid border p-2 bg-light shadow-sm" style="max-height: 250px;" />
                        </div>
                        <div class="col-sm-7 ps-sm-4" style="border-left: 1px solid #dee2e6;">
                            <span class="text-uppercase text-muted small d-block mb-2 tracking-wide fw-500">Thông tin tài khoản nhà hàng</span>
                            <p class="mb-1 text-muted">Ngân hàng chủ quản:</p>
                            <p class="fw-bold text-navy mb-2">PVcomBank (Ngân hàng Đại Chúng Việt Nam)</p>

                            <p class="mb-1 text-muted">Số tài khoản:</p>
                            <p class="fw-bold text-navy fs-5 mb-2 tracking-wide">1070 0372 0588</p>

                            <p class="mb-1 text-muted">Chủ tài khoản:</p>
                            <p class="fw-bold text-navy text-uppercase mb-3">TRẦN HOÀNG DUY</p>

                            <p class="mb-0 text-muted">Số tiền cọc cần chuyển chính xác (20%):</p>
                            <h4 class="text-danger fw-bold mt-1" id="modalSoTien">0 VNĐ</h4>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="p-3 text-center border" style="background-color: #FAF7F2; border-color: #F5EDDA !important;">
                        <span class="text-danger text-uppercase small d-block mb-1 fw-600"><i class="bi bi-exclamation-triangle-fill me-1"></i>Nội dung ghi chính xác cú pháp sau</span>
                        <h4 class="m-0 text-navy tracking-wide" style="font-family: 'Jost', sans-serif; font-weight: 600;">
                            CÚ PHÁP CHUYỂN KHOẢN: <span class="text-primary border-bottom border-primary border-2" id="modalCuPhap">#WHD-00</span>
                        </h4>
                    </div>
                </div>

                <div class="modal-footer border-0 bg-light rounded-0 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-dark rounded-0 px-4" data-bs-dismiss="modal">Quay lại</button>
                    <button type="button" class="btn text-white rounded-0 px-4" style="background-color: #0E1B2E;" onclick="xacNhanDaThanhToan()">Tôi đã thanh toán cọc</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        let activeBookingId = null;

        document.addEventListener('DOMContentLoaded', async () => {
        const username = localStorage.getItem('username');
        if (!username) {
        alert("Vui lòng đăng nhập để xem thông tin!");
        window.location.href = '/Home/Index';
        return;
        }

        document.getElementById('txtUsername').value = username;
        try {
        const res = await fetch(`/api/Taikhoan/get-profile?username=${username}`);
        if (res.ok) {
        const dbData = await res.json();
        document.getElementById('navUserFullName').innerText = dbData.hoTen;
        document.getElementById('txtMaKhachHang').value = dbData.maKhachHang;
        document.getElementById('txtFullName').value = dbData.hoTen;
        document.getElementById('txtPhone').value = dbData.dienThoai || '';
        document.getElementById('txtEmail').value = dbData.email || '';
        localStorage.setItem('fullName', dbData.hoTen);
        } else {
        document.getElementById('navUserFullName').innerText = username;
        console.warn("Chưa thể kết nối tới DB, đang hiển thị tạm.");
        }
        } catch (err) {
        document.getElementById('navUserFullName').innerText = username;
        console.error("Lỗi khi bốc dữ liệu từ DB:", err);
        }

        const historyTab = document.getElementById('list-history-list');
        historyTab.addEventListener('shown.bs.tab', function () {
        loadBookingHistory(username);
        });
        });

        async function loadBookingHistory(username) {
        const tbody = document.getElementById('tableHistoryBody');
        if (!username) return;
        try {
        const response = await fetch(`/api/Taikhoan/history?username=${username}`);
        if (!response.ok) throw new Error('Network error');
        const data = await response.json();
        if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Chưa có đơn đặt tiệc.</td></tr>';
        return;
        }

        tbody.innerHTML = '';
        data.forEach(item => {
        const tienThanhTien = item.tongTien || 0;
        const tienCocGoc = tienThanhTien * 0.20;
        const trangThaiDon = item.trangThai || 0;

        let soNgayTre = 0;
        let tienPhat = 0;

        if (trangThaiDon === 0) {
        const ngayLapDon = new Date(item.ngayLap || new Date());
        const ngayHienTai = new Date();
        const diffTime = ngayHienTai - ngayLapDon;
        const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

        soNgayTre = diffDays > 1 ? diffDays - 1 : 0;
        tienPhat = soNgayTre * (tienThanhTien * 0.01);
        }

        const tongTienCocCanThanhToan = tienCocGoc + tienPhat;

        let statusBadge = '';
        let actionBtn = '';

        if (trangThaiDon === 0) {
        statusBadge = `<span class="badge bg-warning text-dark">Chờ thanh toán cọc</span>`;
        actionBtn = `
        <div class="d-flex gap-2">
        <button class="btn btn-sm text-white rounded-0" style="background-color: #0E1B2E;" onclick="thanhToanCoc(${item.maDatTiecCuoi}, ${tongTienCocCanThanhToan})">Thanh toán cọc</button>
        <button class="btn btn-sm btn-outline-danger rounded-0" onclick="huyDatTiec(${item.maDatTiecCuoi}, false)">Hủy đặt tiệc</button>
        </div>
        `;
        } else if (trangThaiDon === 1) {
        statusBadge = `<span class="badge bg-info text-dark">Đã thanh toán cọc</span>`;
        actionBtn = `
        <div class="d-flex gap-2 align-items-center">
        <span class="text-muted small">Chờ tất toán</span>
        <button class="btn btn-sm btn-outline-danger rounded-0" onclick="huyDatTiec(${item.maDatTiecCuoi}, true)">Hủy đặt tiệc</button>
        </div>
        `;
        } else if (trangThaiDon === 9) {
        statusBadge = `<span class="badge bg-secondary text-white"><i class="bi bi-hourglass-split me-1"></i>Đang xử lý</span>`;
        actionBtn = `<span class="text-muted small italic">Đang chờ hệ thống kiểm tra sao kê...</span>`;
        } else {
        statusBadge = `<span class="badge bg-success">Đã hoàn tất</span>`;
        actionBtn = `<i class="bi bi-check-circle-fill text-success fs-5"></i>`;
        }

        let ghiChuPhat = soNgayTre > 0 ? `<br><small class="text-danger">(+${tienPhat.toLocaleString('vi-VN')} đ phạt trễ ${soNgayTre} ngày)</small>` : '';

        tbody.innerHTML += `
        <tr>
        <td class="fw-bold text-primary">#WHD-${item.maDatTiecCuoi}</td>
        <td>${new Date(item.ngayDaiTiec).toLocaleDateString('vi-VN')}</td>
        <td>Sảnh ${item.maSanh} <br><small class="text-muted">Ca: ${item.maCa}</small></td>
        <td>${item.tenCoDau} - ${item.tenChuRe}</td>
        <td class="fw-bold">${tienThanhTien.toLocaleString('vi-VN')} đ</td>
        <td class="fw-bold text-danger">
        ${tongTienCocCanThanhToan.toLocaleString('vi-VN')} đ
        ${ghiChuPhat}
        </td>
        <td id="status_cell_${item.maDatTiecCuoi}">${statusBadge}</td>
        <td id="action_cell_${item.maDatTiecCuoi}">${actionBtn}</td>
        </tr>
        `;
        });
        } catch (error) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger py-4">Lỗi tải dữ liệu. Bạn hãy kiểm tra lại API!</td></tr>';
        }
        }

        function thanhToanCoc(maDon, soTien) {
        activeBookingId = maDon;
        document.getElementById('modalSoTien').innerText = `${soTien.toLocaleString('vi-VN')} VNĐ`;
        document.getElementById('modalCuPhap').innerText = `#WHD-${maDon}`;
        const pModal = new bootstrap.Modal(document.getElementById('paymentModal'));
        pModal.show();
        }

        // 🌟 ĐÃ SỬA: Hàm gửi yêu cầu AJAX POST đồng bộ trạng thái thật (TrangThai = 9) lên C# Controller
        async function xacNhanDaThanhToan() {
        if (!activeBookingId) return;

        try {
        // 1. Thực hiện gửi yêu cầu POST đến Server API xử lý bất đồng bộ
        const res = await fetch(`/api/Booking/confirm-payment/${activeBookingId}`, {
        method: 'POST'
        });

        const data = await res.json();

        if (res.ok) {
        // Hiển thị thông báo phản hồi thành công từ Backend
        alert(data.message);

        // 2. Định vị cấu trúc Modal và thực hiện đóng ẩn phần tử giao diện
        const modalElement = document.getElementById('paymentModal');
        const modalInstance = bootstrap.Modal.getInstance(modalElement);
        if (modalInstance) {
        modalInstance.hide();
        }

        // 3. Tiến hành cập nhật trực tiếp mã HTML thành trạng thái Đang xử lý
        const statusCell = document.getElementById(`status_cell_${activeBookingId}`);
        const actionCell = document.getElementById(`action_cell_${activeBookingId}`);

        if (statusCell) {
        statusCell.innerHTML = `<span class="badge bg-secondary text-white"><i class="bi bi-hourglass-split me-1"></i>Đang xử lý</span>`;
        }
        if (actionCell) {
        actionCell.innerHTML = `<span class="text-muted small italic"><i class="bi bi-shield-check text-muted me-1"></i>Đang chờ duyệt...</span>`;
        }

        // Giải phóng mã đơn tạm thời
        activeBookingId = null;
        } else {
        alert(data.message || "Có lỗi xảy ra khi gửi xác nhận thanh toán.");
        }
        } catch (err) {
        console.error(err);
        alert("Không thể kết nối với máy chủ để xử lý lệnh xác nhận.");
        }
        }

        async function huyDatTiec(maDon, daNopCoc) {
        let message = "Bạn có chắc chắn muốn hủy đơn đặt tiệc này không?";
        if (daNopCoc) {
        message = "Cảnh báo: Đơn đặt tiệc này đã được thanh toán tiền cọc thành công.\nNếu bạn thực hiện lệnh hủy, quý khách sẽ KHÔNG được hoàn trả tiền cọc!\n\nBạn vẫn muốn tiếp tục hủy chứ?";
        }

        const confirmChoice = confirm(message);
        if (!confirmChoice) return;
        try {
        const res = await fetch(`/api/Booking/delete/${maDon}`, {
        method: 'DELETE'
        });
        const data = await res.json();

        if (res.ok) {
        alert("Hủy đơn đặt tiệc và xóa sạch toàn bộ dữ liệu thành công!");
        const username = localStorage.getItem('username');
        loadBookingHistory(username);
        } else {
        alert(data.message || "Có lỗi xảy ra trong quá trình hủy đơn.");
        }
        } catch (err) {
        console.error(err);
        alert("Không thể kết nối đồng bộ hóa với máy chủ để xử lý lệnh xóa.");
        }
        }
    </script>
</body>
</html>