@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thực Đơn Trọn Gói — Wedding House</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            :root {
                --gold: #C9A84C;
                --navy: #0E1B2E;
                --ivory: #FAF7F2;
                --charcoal: #2C2C2C;
                --font-display: 'Cormorant Garamond', Georgia, serif;
                --font-body: 'Jost', sans-serif;
            }

            body {
                font-family: var(--font-body);
                background: var(--navy);
                color: #fff;
            }

            .menu-header {
                padding: 5rem 0 3rem;
                text-align: center;
                border-bottom: 1px solid rgba(201,168,76,0.2);
            }

            .menu-title {
                font-family: var(--font-display);
                font-size: 3.5rem;
                font-style: italic;
                color: var(--gold);
            }
            /* Bộ lọc Filter Tabs */
            .filter-btn {
                background: transparent;
                color: rgba(255,255,255,0.6);
                border: 1px solid rgba(201,168,76,0.3);
                padding: 0.5rem 1.5rem;
                text-transform: uppercase;
                font-size: 0.8rem;
                letter-spacing: 0.1em;
                transition: all 0.3s;
            }

                .filter-btn:hover, .filter-btn.active {
                    background: var(--gold);
                    color: var(--navy);
                    border-color: var(--gold);
                }
            /* Card món ăn */
            .dish-card {
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(201,168,76,0.15);
                transition: all 0.3s;
                height: 100%;
            }

                .dish-card:hover {
                    background: rgba(201,168,76,0.06);
                    border-color: var(--gold);
                    transform: translateY(-3px);
                }

            .dish-img {
                height: 180px;
                object-fit: cover;
                width: 100%;
            }

            .dish-name {
                font-family: var(--font-display);
                font-size: 1.25rem;
                font-style: italic;
                color: #fff;
            }

            .dish-price {
                color: var(--gold);
                font-weight: 500;
            }
    </style>
</head>
<body>

    <div class="container pt-4">
        <a href="/Home/Index" class="btn btn-outline-light btn-sm rounded-0">
            <i class="bi bi-arrow-left"></i> Quay lại Trang Chủ
        </a>
    </div>

    <header class="menu-header">
        <div class="container">
            <h1 class="menu-title">Tuyệt Tác Ẩm Thực</h1>
            <p class="text-white-50 max-width-600 mx-auto mt-2"> Khám phá danh mục trọn gói 101 món ăn cung đình và hiện đại được chuẩn bị công phu cho ngày chung đôi.</p>

            <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
                <button class="btn filter-btn active" onclick="filterMenu('Tất cả', this)">Tất cả (101)</button>
                <button class="btn filter-btn" onclick="filterMenu('Khai vị', this)">Món Khai Vị</button>
                <button class="btn filter-btn" onclick="filterMenu('Món chính', this)">Món Chính</button>
                <button class="btn filter-btn" onclick="filterMenu('Tráng miệng', this)">Món Tráng Miệng</button>
            </div>
        </div>
    </header>

    <main class="container py-5">
        <div class="row g-4" id="fullMenuContainer">
            <div class="text-center w-100 py-5">
                <span class="spinner-border text-warning"></span>
                <p class="mt-2 text-white-50">Hệ thống đang đồng bộ dữ liệu tinh hoa ẩm thực...</p>
            </div>
        </div>
    </main>

    <script>
            let allDishesData = []; // Kho lưu trữ tạm thời 101 món ăn sau khi fetch

            document.addEventListener('DOMContentLoaded', async () => {
                try {
                    // Gọi vào API PublicData có sẵn của bạn để lôi 101 món lên
                    const response = await fetch('/api/PublicData/dishes');
                    if (!response.ok) throw new Error('Không thể tải danh sách món ăn');
                    allDishesData = await response.json();

                    // Hiển thị toàn bộ món ăn lên màn hình lần đầu
                    renderMenu(allDishesData);
                } catch (error) {
                    console.error(error);
                    document.getElementById('fullMenuContainer').innerHTML = `<div class='text-center text-danger'>Lỗi kết nối máy chủ dữ liệu.</div>`;
                }
            });

            // Hàm vẽ giao diện động dựa trên mảng dữ liệu truyền vào
            function renderMenu(dishesList) {
                const container = document.getElementById('fullMenuContainer');
                if (!container) return;
                container.innerHTML = '';

                if (dishesList.length === 0) {
                    container.innerHTML = `<div class='text-center text-white-50 py-5 w-100'>Hiện chưa có món ăn nào thuộc nhóm này.</div>`;
                    return;
                }

                dishesList.forEach(mon => {
                    const tenMon = mon.tenMon || 'Món ăn Wedding House';
                    const loaiMon = mon.loaiMon || 'Món chính';
                    const moTa = mon.moTa || 'Hương vị thơm ngon tinh tế.';
                    const donGia = mon.donGia || 0;
                    const hinhAnh = mon.hinhanh || 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=600&q=80';

                    container.innerHTML += `
                        <div class="col-sm-6 col-md-4 col-lg-3">
                            <div class="card dish-card rounded-0">
                                <img src="${hinhAnh}" class="card-img-top dish-img rounded-0" alt="${tenMon}">
                                <div class="card-body d-flex flex-column justify-content-between">
                                    <div>
                                        <span class="badge bg-dark text-warning rounded-0 mb-2 small text-uppercase" style="font-size:0.6rem; letter-spacing:0.1em;">${loaiMon}</span>
                                        <h5 class="dish-name">${tenMon}</h5>
                                        <p class="card-text text-white-50 small style="font-size:0.8rem;">${moTa}</p>
                                    </div>
                                    <div class="dish-price mt-3 fs-6">${donGia.toLocaleString('vi-VN')} VNĐ</div>
                                </div>
                            </div>
                        </div>
                    `;
                });
            }

            // Logic xử lý khi người dùng nhấn chuyển đổi tab phân loại
            function filterMenu(category, buttonElement) {
                // Đổi class Active cho nút
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                buttonElement.classList.add('active');

                if (category === 'Tất cả') {
                    renderMenu(allDishesData);
                } else {
                    // Lọc dữ liệu theo đúng "loaiMon" mà API trả về
                    const filtered = allDishesData.filter(d => d.loaiMon === category);
                    renderMenu(filtered);
                }
            }
    </script>
</body>
</html>