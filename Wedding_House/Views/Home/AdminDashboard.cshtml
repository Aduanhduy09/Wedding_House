<!-- ── 3. ĐOẠN SCRIPT JAVASCRIPT ĐỌC API KÉO DỮ LIỆU THẬT ── -->
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('token');

            try {
                // Bắn lệnh fetch ngầm sang API thống kê DashboardApiController
                const response = await fetch('/api/dashboardapi/stats', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (response.ok) {
                    const data = await response.json();

                    // 1. Gắn số liệu đếm thật vào card
                    document.getElementById('txtRevenue').textContent = data.revenue;
                    document.getElementById('txtDishesCount').textContent = data.dishesCount;

                    // 2. Bóc mảng tài khoản SQL render thành các dòng tr
                    const tableBody = document.getElementById('recentBookingsBody');
                    tableBody.innerHTML = '';

                    data.recentData.forEach(item => {
                        const row = `
                            <tr>
                                <td>
                                    <span class="customer-avatar">${item.username.substring(0, 2).toUpperCase()}</span>
                                    <span class="customer-name">${item.username}</span>
                                </td>
                                <td><i class="bi bi-shield-lock text-primary me-1" style="font-size:.8rem"></i>${item.role}</td>
                                <td>Vừa quét xong</td>
                                <td><span class="badge-status badge-paid"><i class="bi bi-check-circle me-1"></i>${item.status}</span></td>
                                <td class="d-flex gap-1">
                                    <button class="btn-icon" onclick="alert('Xem tài khoản hệ thống: ${item.username}')"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                        `;
                        tableBody.innerHTML += row;
                    });

                } else {
                    console.error('Lỗi phản hồi từ API thống kê!');
                }
            } catch (error) {
                console.error('Không thể kết nối đến API Dashboard:', error);
            }
        });

        /* Hiệu ứng gạch ngang của checkbox việc cần làm */
        document.querySelectorAll('.task-check').forEach(cb => {
            cb.addEventListener('change', () => {
                const label = cb.closest('.task-item').querySelector('.task-label');
                label.classList.toggle('done', cb.checked);
            });
        });
    </script>
}

