
@{
    ViewData["Title"] = "Bảng Điều Khiển Quản Trị";
}

<!-- ── 1. TOÀN BỘ CSS TÙY BIẾN CAO CẤP (BÓC TỪ DASHBOARD.TXT) ── -->
<style>
    :root {
        /* Đồng bộ các biến màu sắc cốt lõi của không gian Dashboard */
        --gold: #c9963c;
        --gold-light: rgba(201,150,60,.10);
        --success: #16a34a;
        --success-light: rgba(22,163,74,.10);
        --warning: #d97706;
        --warning-light: rgba(217,119,6,.10);
        --danger: #dc2626;
        --danger-light: rgba(220,38,38,.10);
        --purple: #7c3aed;
        --purple-light: rgba(124,58,237,.10);
        --radius: 14px;
    }

    /* Page header */
    .page-header .greeting {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.85rem;
        font-weight: 700;
        letter-spacing: -.5px;
        margin: 0;
    }

    .page-header .sub {
        font-size: .84rem;
        color: var(--text-muted);
        margin: .2rem 0 0;
    }

    .page-header .date-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: .4rem .9rem;
        font-size: .8rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* Metric Cards */
    .metric-card {
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }

        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(15,23,42,.08);
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--radius) var(--radius) 0 0;
        }

    .mc-blue::before {
        background: var(--accent);
    }

    .mc-gold::before {
        background: var(--gold);
    }

    .mc-green::before {
        background: var(--success);
    }

    .mc-purple::before {
        background: var(--purple);
    }

    .metric-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        margin-bottom: 1rem;
    }

    .metric-label {
        font-size: .78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--text-muted);
        margin: 0 0 .3rem;
    }

    .metric-value {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.9rem;
        font-weight: 700;
        line-height: 1;
        margin: 0 0 .5rem;
    }

    .metric-delta {
        font-size: .78rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .18rem .55rem;
        border-radius: 20px;
    }

    .delta-up {
        background: var(--success-light);
        color: var(--success);
    }

    .delta-down {
        background: var(--danger-light);
        color: var(--danger);
    }

    /* Section card */
    .section-card {
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .section-header {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .section-title {
        font-weight: 600;
        font-size: .95rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .45rem;
    }

        .section-title i {
            color: var(--accent);
        }

    /* Table */
    .wh-table {
        margin: 0;
    }

        .wh-table thead th {
            background: #f8fafc;
            font-size: .73rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
            padding: .75rem 1.2rem;
        }

        .wh-table tbody td {
            padding: .85rem 1.2rem;
            vertical-align: middle;
            font-size: .875rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .wh-table tbody tr:last-child td {
            border-bottom: none;
        }

        .wh-table tbody tr:hover td {
            background: #f8faff;
        }

    .customer-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: rgba(37,99,235,.10);
        color: var(--accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
        font-weight: 700;
        margin-right: .5rem;
    }

    .customer-name {
        font-weight: 500;
    }

    /* Status badges */
    .badge-status {
        font-size: .72rem;
        font-weight: 600;
        padding: .3rem .7rem;
        border-radius: 20px;
        letter-spacing: .3px;
    }

    .badge-paid {
        background: var(--success-light);
        color: var(--success);
    }

    .badge-pending {
        background: var(--warning-light);
        color: var(--warning);
    }

    .badge-cancelled {
        background: var(--danger-light);
        color: var(--danger);
    }

    .btn-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-muted);
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

        .btn-icon:hover {
            color: var(--accent);
            border-color: var(--accent);
            background: rgba(37,99,235,.10);
        }

    /* Checklist */
    .task-body {
        padding: 1rem 1.5rem;
    }

    .task-item {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
        padding: .7rem 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .task-item:last-child {
            border-bottom: none;
        }

    .task-check {
        width: 18px;
        height: 18px;
        border: 2px solid var(--border);
        border-radius: 5px;
        cursor: pointer;
        flex-shrink: 0;
        margin-top: 1px;
        transition: all .15s;
    }

    .task-label {
        font-size: .865rem;
    }

        .task-label.done {
            text-decoration: line-through;
            color: var(--text-muted);
        }

    .task-meta {
        font-size: .75rem;
        color: var(--text-muted);
        margin-top: .15rem;
    }

    .task-priority {
        font-size: .68rem;
        padding: .15rem .5rem;
        border-radius: 20px;
        font-weight: 600;
        margin-left: auto;
        flex-shrink: 0;
    }

    .tp-high {
        background: var(--danger-light);
        color: var(--danger);
    }

    .tp-med {
        background: var(--warning-light);
        color: var(--warning);
    }

    .tp-low {
        background: var(--success-light);
        color: var(--success);
    }

    /* Availability grid */
    .avail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
        padding: 1rem 1.5rem 1.5rem;
    }

    .avail-slot {
        border-radius: 10px;
        padding: .75rem .9rem;
        font-size: .8rem;
        font-weight: 500;
    }

        .avail-slot .slot-name {
            font-weight: 600;
            font-size: .85rem;
            margin-bottom: .2rem;
        }

        .avail-slot .slot-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: .35rem;
        }

    .slot-available {
        background: var(--success-light);
        color: var(--success);
    }

    .slot-busy {
        background: var(--danger-light);
        color: var(--danger);
    }

    .slot-maint {
        background: var(--warning-light);
        color: var(--warning);
    }

    /* Mini chart area */
    .mini-chart {
        padding: .5rem 1.5rem 1rem;
    }

    .chart-bars {
        display: flex;
        align-items: flex-end;
        gap: .5rem;
        height: 80px;
    }

    .chart-bar-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .3rem;
        flex: 1;
    }

    .chart-bar {
        width: 100%;
        border-radius: 5px 5px 0 0;
        background: rgba(37,99,235,.10);
        transition: background .2s;
        cursor: pointer;
        min-height: 4px;
    }

        .chart-bar:hover, .chart-bar.active {
            background: var(--accent);
        }

    .chart-bar-label {
        font-size: .68rem;
        color: var(--text-muted);
    }

    .link-subtle {
        font-size: .8rem;
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
    }

        .link-subtle:hover {
            text-decoration: underline;
        }
</style>

<!-- ── 2. KHU VỰC THẺ HTML NỘI DUNG CHÍNH (BÓC TỪ BODY DASHBOARD.TXT) ── -->
<div class="container-fluid py-2">

    <!-- Page header -->
    <div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2 mb-4">
        <div>
            <h1 class="greeting">Chào buổi sáng, Admin 👋</h1>
            <p class="sub">Hôm nay có <strong>3 tiệc cưới</strong> đang diễn ra. Chúc một ngày làm việc suôn sẻ.</p>
        </div>
        <span class="date-badge">
            <i class="bi bi-calendar3"></i>
            Thứ Ba, 02 tháng 6, 2026
        </span>
    </div>

    <!-- Metric cards -->
    <div class="row g-4 mb-4">
        <div class="col-6 col-xl-3">
            <div class="metric-card mc-blue">
