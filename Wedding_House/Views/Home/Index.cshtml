@{
    // 🌟 ĐỨT LIÊN KẾT LAYOUT: Trang này dành cho khách xem công khai, không dùng chung khung Sidebar tối của Admin
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wedding House — Nơi Chắp Cánh Cho Hạnh Phúc Lứa Đôi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            :root {
                --gold: #C9A84C;
                --gold-light: #E8C97A;
                --gold-pale: #F5EDDA;
                --navy: #0E1B2E;
                --navy-mid: #1C2F4A;
                --ivory: #FAF7F2;
                --charcoal: #2C2C2C;
                --muted: #6B7280;
                --font-display: 'Cormorant Garamond', Georgia, serif;
                --font-body: 'Jost', sans-serif;
            }

            *, *::before, *::after {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: var(--font-body);
                background: var(--ivory);
                color: var(--charcoal);
                overflow-x: hidden;
            }

            /* NAVBAR */
            .wh-navbar {
                background: rgba(14, 27, 46, 0.96);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(201,168,76,0.25);
                padding: 0.75rem 0;
                transition: all 0.3s ease;
            }

                .wh-navbar .navbar-brand {
                    font-family: var(--font-display);
                    font-size: 1.7rem;
                    font-weight: 600;
                    color: var(--gold) !important;
                    letter-spacing: 0.03em;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                    .wh-navbar .navbar-brand .brand-icon {
                        width: 32px;
                        height: 32px;
                        border: 1.5px solid var(--gold);
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 0.9rem;
                        color: var(--gold);
                    }

                .wh-navbar .nav-link {
                    font-family: var(--font-body);
                    font-size: 0.82rem;
                    font-weight: 500;
                    letter-spacing: 0.12em;
                    text-transform: uppercase;
                    color: rgba(255,255,255,0.75) !important;
                    padding: 0.5rem 1rem !important;
                    position: relative;
                    transition: color 0.25s;
                }

                    .wh-navbar .nav-link::after {
                        content: '';
                        position: absolute;
                        bottom: 2px;
                        left: 50%;
                        right: 50%;
                        height: 1px;
                        background: var(--gold);
                        transition: left 0.3s, right 0.3s;
                    }

                    .wh-navbar .nav-link:hover, .wh-navbar .nav-link.active {
                        color: var(--gold) !important;
                    }

                        .wh-navbar .nav-link:hover::after, .wh-navbar .nav-link.active::after {
                            left: 1rem;
                            right: 1rem;
                        }

            .btn-auth {
                font-family: var(--font-body);
                font-size: 0.8rem;
                font-weight: 500;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--gold) !important;
                border: 1px solid var(--gold);
                border-radius: 0;
                padding: 0.45rem 1.2rem;
                background: transparent;
                transition: all 0.3s;
                text-decoration: none;
                display: inline-block;
            }

                .btn-auth:hover {
                    background: var(--gold);
                    color: var(--navy) !important;
                }

            /* HERO */
            .hero-section {
                min-height: 100vh;
                position: relative;
                display: flex;
                align-items: center;
                overflow: hidden;
            }

            .hero-bg {
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(14,27,46,0.82) 0%, rgba(14,27,46,0.45) 60%, rgba(201,168,76,0.15) 100%), url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1920&q=80') center/cover no-repeat;
                transform-origin: center;
                animation: heroZoom 18s ease-in-out infinite alternate;
            }

            @@keyframes heroZoom {
                from {
                    transform: scale(1);
                }

                to {
                    transform: scale(1.06);
                }
            }

            .hero-ornament::before, .hero-ornament::after {
                content: '';
                position: absolute;
                border: 1px solid rgba(201,168,76,0.2);
                border-radius: 50%;
            }

            .hero-ornament::before {
                width: 600px;
                height: 600px;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

            .hero-ornament::after {
                width: 820px;
                height: 820px;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

            .hero-content {
                position: relative;
                z-index: 2;
            }

            .hero-label {
                font-family: var(--font-body);
                font-size: 0.72rem;
                letter-spacing: 0.3em;
                text-transform: uppercase;
                color: var(--gold-light);
                margin-bottom: 1.5rem;
                display: flex;
                align-items: center;
                gap: 1rem;
            }

                .hero-label::before, .hero-label::after {
                    content: '';
                    flex: 1;
                    max-width: 60px;
                    height: 1px;
                    background: var(--gold);
                    opacity: 0.6;
                }

            .hero-title {
                font-family: var(--font-display);
                font-size: clamp(2.8rem, 6vw, 5.5rem);
                font-weight: 300;
                font-style: italic;
                color: #fff;
                line-height: 1.15;
                margin-bottom: 1.2rem;
                animation: fadeUp 1s ease both;
            }

                .hero-title span {
                    color: var(--gold-light);
                    font-style: italic;
                }

            .hero-subtitle {
                font-family: var(--font-body);
                font-size: 1rem;
                font-weight: 300;
                color: rgba(255,255,255,0.72);
                letter-spacing: 0.05em;
                max-width: 480px;
                margin-bottom: 2.5rem;
                animation: fadeUp 1s 0.2s ease both;
            }

            .btn-gold {
                font-family: var(--font-body);
                font-size: 0.8rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                background: var(--gold);
                color: var(--navy);
                border: 2px solid var(--gold);
                padding: 0.85rem 2.2rem;
                border-radius: 0;
                transition: all 0.3s;
                text-decoration: none;
            }

                .btn-gold:hover {
                    background: transparent;
                    color: var(--gold-light);
                }

            .btn-outline-gold {
                font-family: var(--font-body);
                font-size: 0.8rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                background: transparent;
                color: rgba(255,255,255,0.85);
                border: 2px solid rgba(255,255,255,0.4);
                padding: 0.85rem 2.2rem;
                border-radius: 0;
                transition: all 0.3s;
                text-decoration: none;
            }

                .btn-outline-gold:hover {
                    border-color: var(--gold);
                    color: var(--gold);
                }

            .hero-scroll {
                position: absolute;
                bottom: 2.5rem;
                left: 50%;
                transform: translateX(-50%);
                z-index: 2;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0.5rem;
                color: rgba(255,255,255,0.45);
                font-size: 0.68rem;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                animation: bounce 2s infinite;
            }

            @@keyframes bounce {
                0%, 100% {
                    transform: translateX(-50%) translateY(0);
                }

                50% {
                    transform: translateX(-50%) translateY(6px);
                }
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(28px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* COMMON SECTION */
            .section-label {
                font-family: var(--font-body);
                font-size: 0.68rem;
                letter-spacing: 0.35em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 0.8rem;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 1rem;
            }

                .section-label::before, .section-label::after {
                    content: '';
                    width: 40px;
                    height: 1px;
                    background: var(--gold);
                    opacity: 0.6;
                }

            .section-title {
                font-family: var(--font-display);
                font-size: clamp(2rem, 4vw, 3.2rem);
                font-weight: 300;
                font-style: italic;
                color: var(--navy);
                margin-bottom: 1rem;
            }

            .section-desc {
                font-size: 0.95rem;
                color: var(--muted);
                max-width: 540px;
                margin: 0 auto 3rem;
                line-height: 1.8;
            }

            /* BALLROOMS */
            .ballrooms-section {
                background: var(--ivory);
                padding: 6rem 0;
            }

            .hall-card {
                position: relative;
                overflow: hidden;
                cursor: pointer;
                box-shadow: 0 4px 30px rgba(14,27,46,0.1);
                transition: box-shadow 0.4s;
            }

                .hall-card:hover {
                    box-shadow: 0 12px 50px rgba(14,27,46,0.18);
                }

            .hall-card-img {
                overflow: hidden;
                height: 280px;
            }

                .hall-card-img img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    transition: transform 0.7s ease;
                }

            .hall-card:hover .hall-card-img img {
                transform: scale(1.08);
            }

            .hall-card-body {
                background: #fff;
                padding: 1.6rem;
                border-top: 2px solid var(--gold);
            }

            .hall-badge {
                font-size: 0.65rem;
                font-weight: 500;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: var(--gold);
                background: var(--gold-pale);
                padding: 0.25rem 0.8rem;
                display: inline-block;
                margin-bottom: 0.8rem;
            }

            .hall-name {
                font-family: var(--font-display);
                font-size: 1.8rem;
                font-weight: 600;
                color: var(--navy);
                margin-bottom: 0.5rem;
            }

            .hall-meta {
                font-size: 0.82rem;
                color: var(--muted);
                display: flex;
                align-items: center;
                gap: 1.2rem;
                margin-bottom: 1rem;
            }

            .hall-price {
                font-family: var(--font-display);
                font-size: 1.25rem;
                color: var(--gold);
                font-style: italic;
                margin-bottom: 1rem;
            }

            .btn-detail {
                font-size: 0.75rem;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--navy);
                text-decoration: none;
                border-bottom: 1px solid var(--navy);
                padding-bottom: 2px;
                transition: color 0.25s, border-color 0.25s;
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
            }

                .btn-detail:hover {
                    color: var(--gold);
                    border-color: var(--gold);
                }

            /* CULINARY */
            .culinary-section {
                background: var(--navy);
                padding: 6rem 0;
                position: relative;
                overflow: hidden;
            }

                .culinary-section::before {
                    content: '';
                    position: absolute;
                    top: -80px;
                    right: -80px;
                    width: 400px;
                    height: 400px;
                    border: 1px solid rgba(201,168,76,0.12);
                    border-radius: 50%;
                }

                .culinary-section::after {
                    content: '';
                    position: absolute;
                    bottom: -100px;
                    left: -100px;
                    width: 500px;
                    height: 500px;
                    border: 1px solid rgba(201,168,76,0.08);
                    border-radius: 50%;
                }

                .culinary-section .section-title {
                    color: #fff;
                }

                .culinary-section .section-desc {
                    color: rgba(255,255,255,0.55);
                }

            .dish-card {
                background: rgba(255,255,255,0.04);
                border: 1px solid rgba(201,168,76,0.2);
                overflow: hidden;
                transition: background 0.3s, border-color 0.3s;
            }

                .dish-card:hover {
                    background: rgba(201,168,76,0.07);
                    border-color: var(--gold);
                }

            .dish-img-wrap {
                height: 200px;
                overflow: hidden;
            }

                .dish-img-wrap img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    transition: transform 0.6s;
                }

            .dish-card:hover .dish-img-wrap img {
                transform: scale(1.05);
            }

            .dish-body {
                padding: 1.4rem;
            }

            .dish-tag {
                font-size: 0.62rem;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: var(--gold);
                background: rgba(201,168,76,0.12);
                padding: 0.2rem 0.7rem;
                display: inline-block;
                margin-bottom: 0.75rem;
            }

            .dish-name {
                font-family: var(--font-display);
                font-size: 1.3rem;
                color: #fff;
                font-style: italic;
                margin-bottom: 0.4rem;
            }

            .dish-desc {
                font-size: 0.82rem;
                color: rgba(255,255,255,0.5);
                line-height: 1.7;
                margin-bottom: 0.8rem;
            }

            .dish-price {
                font-family: var(--font-display);
                font-size: 1.2rem;
                color: var(--gold-light);
                font-style: italic;
            }

            /* SERVICES */
            .services-section {
                background: var(--ivory);
                padding: 6rem 0;
            }

            .service-item {
                text-align: center;
                padding: 2.5rem 1.5rem;
                border: 1px solid rgba(14,27,46,0.08);
                background: #fff;
                position: relative;
                overflow: hidden;
                transition: all 0.35s;
            }

                .service-item::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    height: 3px;
                    background: linear-gradient(90deg, transparent, var(--gold), transparent);
                    transform: scaleX(0);
                    transition: transform 0.4s;
                }

                .service-item:hover {
                    box-shadow: 0 8px 40px rgba(14,27,46,0.1);
                    transform: translateY(-4px);
                }

                    .service-item:hover::after {
                        transform: scaleX(1);
                    }

            .service-icon {
                width: 64px;
                height: 64px;
                border: 1px solid rgba(201,168,76,0.4);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1.4rem;
                font-size: 1.5rem;
                color: var(--gold);
                background: var(--gold-pale);
                transition: all 0.3s;
            }

            .service-item:hover .service-icon {
                background: var(--gold);
                color: var(--navy);
                border-color: var(--gold);
            }

            .service-name {
                font-family: var(--font-display);
                font-size: 1.25rem;
                font-style: italic;
                color: var(--navy);
                margin-bottom: 0.5rem;
            }

            .service-desc {
                font-size: 0.82rem;
                color: var(--muted);
                line-height: 1.7;
            }

            /* QUOTE */
            .quote-section {
                background: linear-gradient(135deg, var(--navy-mid), var(--navy));
                padding: 5rem 0;
            }

            .quote-text {
                font-family: var(--font-display);
                font-size: clamp(1.6rem, 3.5vw, 2.8rem);
                font-style: italic;
                font-weight: 300;
                color: #fff;
                line-height: 1.4;
            }

                .quote-text span {
                    color: var(--gold-light);
                }

            .quote-author {
                font-size: 0.78rem;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: rgba(255,255,255,0.4);
                margin-top: 1.5rem;
            }

            /* FOOTER */
            .wh-footer {
                background: #060D18;
                color: rgba(255,255,255,0.6);
                padding: 5rem 0 2rem;
            }

            .footer-brand {
                font-family: var(--font-display);
                font-size: 2.2rem;
                font-weight: 600;
                font-style: italic;
                color: var(--gold);
                margin-bottom: 1rem;
            }

            .footer-tagline {
                font-size: 0.82rem;
                color: rgba(255,255,255,0.35);
                letter-spacing: 0.1em;
                line-height: 1.8;
                max-width: 260px;
            }

            .footer-heading {
                font-family: var(--font-body);
                font-size: 0.7rem;
                font-weight: 500;
                letter-spacing: 0.25em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 1.5rem;
                padding-bottom: 0.75rem;
                border-bottom: 1px solid rgba(201,168,76,0.2);
            }

            .footer-links {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .footer-links li {
                    margin-bottom: 0.6rem;
                }

                .footer-links a {
                    font-size: 0.85rem;
                    color: rgba(255,255,255,0.45);
                    text-decoration: none;
                    transition: all 0.25s;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                    .footer-links a:hover {
                        color: var(--gold-light);
                        padding-left: 4px;
                    }

            .social-icons {
                display: flex;
                gap: 0.75rem;
                margin-top: 1.5rem;
            }

                .social-icons a {
                    width: 36px;
                    height: 36px;
                    border: 1px solid rgba(201,168,76,0.3);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: rgba(255,255,255,0.5);
                    font-size: 0.9rem;
                    text-decoration: none;
                    transition: all 0.3s;
                }

                    .social-icons a:hover {
                        background: var(--gold);
                        border-color: var(--gold);
                        color: var(--navy);
                    }

            .footer-divider {
                border-color: rgba(255,255,255,0.08);
                margin: 3rem 0 1.5rem;
            }

            .footer-bottom {
                font-size: 0.75rem;
                color: rgba(255,255,255,0.25);
                text-align: center;
            }

            .hours-row {
                display: flex;
                justify-content: space-between;
                font-size: 0.83rem;
                margin-bottom: 0.5rem;
                padding-bottom: 0.5rem;
                border-bottom: 1px solid rgba(255,255,255,0.06);
            }

                .hours-row span:first-child {
                    color: rgba(255,255,255,0.4);
                }

                .hours-row span:last-child {
                    color: var(--gold-light);
                }

            /* SCROLL REVEAL */
            .reveal {
                opacity: 0;
                transform: translateY(30px);
                transition: opacity 0.7s ease, transform 0.7s ease;
            }

                .reveal.visible {
                    opacity: 1;
                    transform: none;
                }

            .reveal-delay-1 {
                transition-delay: 0.1s;
            }

            .reveal-delay-2 {
                transition-delay: 0.2s;
            }

            .reveal-delay-3 {
                transition-delay: 0.3s;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg wh-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <span class="brand-icon"><i class="bi bi-heart-fill" style="font-size:0.7rem"></i></span>
                Wedding House
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="bi bi-list text-white fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-lg-1">
                    <li class="nav-item"><a class="nav-link active" href="#">Trang Chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#saloons">Sảnh Tiệc</a></li>
                    <li class="nav-item"><a class="nav-link" href="#culinary">Thực Đơn</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Dịch Vụ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#footer">Liên Hệ</a></li>
                </ul>

                <div class="d-flex align-items-center gap-3" id="navAuthSection">
                    <a href="/Taikhoan/Login" class="btn btn-auth">
                        <i class="bi bi-person me-1"></i> Đăng Nhập / Đăng Ký
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-section">
        <div class="hero-bg"></div>
        <div class="hero-ornament"></div>
        <div class="container hero-content">
            <div class="row justify-content-start">
                <div class="col-lg-8 col-xl-7">
                    <p class="hero-label">Nhà hàng tiệc cưới cao cấp</p>
                    <h1 class="hero-title">
                        Nơi Chắp Cánh Cho<br />
                        <span>Hạnh Phúc Lứa Đôi</span>
                    </h1>
                    <p class="hero-subtitle">
                        Mỗi khoảnh khắc tại Wedding House là một trang thơ — nơi tình yêu được tôn vinh bằng không gian sang trọng, ẩm thực tinh tế và dịch vụ tận tâm.
                    </p>
                    <div class="hero-cta">
                        <a href="/Taikhoan/Login" class="btn btn-gold">
                            <i class="bi bi-calendar-heart me-2"></i>Đặt Tiệc Ngay
                        </a>
                        <a href="#saloons" class="btn btn-outline-gold">
                            Khám Phá Sảnh <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-scroll">
            <i class="bi bi-chevron-double-down"></i>
            <span>Khám phá</span>
        </div>
    </section>

    <div style="background: var(--navy); padding: 2rem 0; border-bottom: 1px solid rgba(201,168,76,0.15)">
        <div class="container">
            <div class="row text-center g-4 justify-content-center">
