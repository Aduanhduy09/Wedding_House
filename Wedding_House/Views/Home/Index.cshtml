    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
        const token = localStorage.getItem('token');
        const username = localStorage.getItem('username');

        // Khách hàng đã đăng nhập thành công từ trước
        if (token && username) {
        const authSection = document.getElementById('navAuthSection');
        if (authSection) {
        // Thay nút Login thành lời chào và tạo nút Thoát có id="btnCustomerLogout"
        authSection.innerHTML = `
        <div class="d-flex align-items-center gap-3">
        <span class="text-white-50 small" style="letter-spacing: 0.05em; text-transform: uppercase;">
        <i class="bi bi-person-circle text-warning me-1"></i> Xin chào,
        <strong class="text-white">${username}</strong>
        </span>
        <a href="#" id="btnCustomerLogout" class="btn-auth" style="padding: 0.35rem 0.9rem; font-size: 0.75rem;">
        <i class="bi bi-box-arrow-right"></i> Thoát
        </a>
        </div>
        `;
        }

        // 🔒 BẮT SỰ KIỆN CLICK TRỰC TIẾP CHO NÚT THOÁT (Xóa sạch bộ nhớ, giải quyết lỗi tự đăng nhập)
        document.getElementById('btnCustomerLogout')?.addEventListener('click', (e) => {
        e.preventDefault();

        localStorage.clear();      // Xóa Token và Username trong bộ nhớ dài hạn
        sessionStorage.clear();    // Dọn sạch phiên làm việc hiện tại

        alert('Đã đăng xuất tài khoản thành công!');

        // Điều hướng tải lại trang chủ sạch sẽ không chứa token
        window.location.href = '/Home/Index';
        });

        // 🛠️ SỬA LỖI NÚT THỰC ĐƠN: Cuộn mượt tại chỗ, chặn chuyển hướng sang Login
        const btnViewMenu = document.getElementById('btnViewMenu');
        if (btnViewMenu) {
        btnViewMenu.setAttribute('href', '#culinary');
        btnViewMenu.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('culinary')?.scrollIntoView({ behavior: 'smooth' });
        alert('Hệ thống đang chuẩn bị tải toàn bộ danh sách thực đơn 100+ món ăn đặc sắc cho bạn...');
        });
        }

        // 🏢 SỬA LỖI NÚT SẢNH TIỆC: Giữ chân khách lại khu vực sảnh tiệc, chặn đá về Login
        const detailButtons = document.querySelectorAll('.btn-detail');
        detailButtons.forEach(btn => {
        btn.setAttribute('href', '#saloons');
        btn.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('saloons')?.scrollIntoView({ behavior: 'smooth' });
        alert('Hệ thống đang kết nối dữ liệu để tải hình ảnh mô phỏng không gian và lịch trống của sảnh tiệc này...');
        });
        });
        }
        });

        // ── GIỮ NGUYÊN ĐOẠN CODE HIỆU ỨNG CUỘN TRANG GỐC CỦA BẠN DƯỚI ĐÂY ──
        const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
        if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
        }
        });
        }, { threshold: 0.12 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Navbar shrink on scroll
        const navbar = document.querySelector('.wh-navbar');
        window.addEventListener('scroll', () => {
        if (window.scrollY > 60) {
        navbar.style.padding = '0.4rem 0';
        } else {
        navbar.style.padding = '0.75rem 0';
        }
        });
    </script>
